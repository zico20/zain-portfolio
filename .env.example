# ─────────────────────────────────────────────────────────────
# Public site URL — used for SEO metadata, OpenGraph, sitemap, robots.
# In production set this to your deployed origin, e.g. https://zain.dev
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Contact form delivery via Resend.
# Without RESEND_API_KEY the /api/contact route still works locally —
# it validates the submission and logs it instead of emailing.
# To deliver real emails: sign up at https://resend.com, create an API
# key, and set RESEND_API_KEY (in production, set it in your Vercel
# project's Environment Variables).
#
# CONTACT_TO_EMAIL is OPTIONAL — it defaults to the email in src/lib/site.ts.
# ─────────────────────────────────────────────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# CONTACT_TO_EMAIL=zainalmawla11@gmail.com

# ─────────────────────────────────────────────────────────────
# Search engine verification tokens (optional).
# Paste the content="..." value from each engine's HTML-tag method.
# Used by src/app/layout.tsx → metadata.verification.
# ─────────────────────────────────────────────────────────────
# NEXT_PUBLIC_GOOGLE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_BING_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
